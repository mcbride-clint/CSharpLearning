@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col">
        <h1>Book Library — Learning Project</h1>
        <p class="lead text-muted">
            An ASP.NET Core 8 MVC + REST API teaching project demonstrating DI,
            EF Core, Middleware, and common design patterns.
        </p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-primary">
            <div class="card-header bg-primary text-white">
                <strong>Singleton — StatisticsService</strong>
            </div>
            <div class="card-body">
                <p class="card-text">
                    <strong>Total Requests:</strong> @ViewBag.TotalRequests<br />
                    <strong>Uptime:</strong> @ViewBag.UptimeSeconds seconds<br />
                    <strong>Started:</strong> @(((DateTime)ViewBag.StartedAt).ToString("HH:mm:ss"))<br />
                    <strong>OperationId:</strong> <code class="small">@ViewBag.ControllerOperationId</code>
                </p>
                <p class="card-text text-muted small">
                    Refresh the page — the counter increments every request.
                    StatisticsService is <strong>Singleton</strong>: one instance shared
                    across all requests for the app's entire lifetime.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-header"><strong>Quick Navigation</strong></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-6">
                        <h6>MVC (Razor Views)</h6>
                        <ul class="small">
                            <li><a asp-controller="Books" asp-action="Index">Books list</a> — EF Core, Strategy sort</li>
                            <li><a asp-controller="Books" asp-action="Create">Add a book</a> — Builder query, validation</li>
                            <li><a asp-controller="Authors" asp-action="Index">Authors</a> — Business rules</li>
                            <li><a asp-controller="Categories" asp-action="Index">Categories</a></li>
                            <li><a asp-controller="Home" asp-action="DiDemo">DI Demo</a> — Lifetime comparison</li>
                        </ul>
                    </div>
                    <div class="col-6">
                        <h6>REST API</h6>
                        <ul class="small">
                            <li><a href="/swagger" target="_blank">Swagger UI</a></li>
                            <li><a href="/api/books" target="_blank">GET /api/books</a></li>
                            <li><a href="/api/books/export?format=csv" target="_blank">Export CSV</a></li>
                            <li><a href="/api/books/export?format=json" target="_blank">Export JSON</a></li>
                            <li><a href="/api/books/search?title=dune" target="_blank">Search API</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col">
        <h5>What This Project Teaches</h5>
        <div class="row">
            <div class="col-md-4">
                <h6 class="text-primary">ASP.NET Core</h6>
                <ul class="small">
                    <li>DI lifetimes (Singleton / Scoped / Transient)</li>
                    <li>Middleware pipeline &amp; ordering</li>
                    <li>MVC controllers, routing, model binding</li>
                    <li>REST API controllers vs MVC controllers</li>
                    <li>Razor Tag Helpers &amp; validation</li>
                    <li>Configuration &amp; structured logging</li>
                </ul>
            </div>
            <div class="col-md-4">
                <h6 class="text-success">EF Core</h6>
                <ul class="small">
                    <li>DbContext (Scoped lifetime)</li>
                    <li>Eager loading with .Include()</li>
                    <li>AsNoTracking() for read-only queries</li>
                    <li>LINQ-to-SQL translation</li>
                    <li>Migrations, Fluent API, seed data</li>
                    <li>SaveChangesAsync() as commit</li>
                </ul>
            </div>
            <div class="col-md-4">
                <h6 class="text-warning">Design Patterns</h6>
                <ul class="small">
                    <li>Guard Clauses</li>
                    <li>Strategy (sort algorithms)</li>
                    <li>Builder (fluent search query)</li>
                    <li>Decorator (transparent caching)</li>
                    <li>Factory (report formatters)</li>
                    <li>Repository &amp; PRG pattern</li>
                </ul>
            </div>
        </div>
    </div>
</div>
