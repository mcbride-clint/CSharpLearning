@model BookLibrary.ViewModels.BookViewModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@Model.Title</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary ms-1">Back</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Author</dt>
    <dd class="col-sm-9">@Model.AuthorName</dd>

    <dt class="col-sm-3">Category</dt>
    <dd class="col-sm-9">@Model.CategoryName</dd>

    <dt class="col-sm-3">ISBN</dt>
    <dd class="col-sm-9">@(Model.ISBN ?? "—")</dd>

    <dt class="col-sm-3">Published</dt>
    <dd class="col-sm-9">@Model.PublishedYear</dd>

    <dt class="col-sm-3">Pages</dt>
    <dd class="col-sm-9">@Model.PageCount</dd>

    <dt class="col-sm-3">Price</dt>
    <dd class="col-sm-9">@Model.Price.ToString("C")</dd>

    <dt class="col-sm-3">Available</dt>
    <dd class="col-sm-9">
        @if (Model.IsAvailable)
        {
            <span class="badge bg-success">Available</span>
        }
        else
        {
            <span class="badge bg-secondary">Unavailable</span>
        }
    </dd>
</dl>

@if (!string.IsNullOrEmpty(Model.Description))
{
    <h5>Description</h5>
    <p>@Model.Description</p>
}
