@model IEnumerable<BookLibrary.ViewModels.BookViewModel>

@*
    RAZOR — @model directive:
    Declares the type of the model passed from the controller.
    With this, 'Model' in the view is strongly typed as IEnumerable<BookViewModel>.
    The compiler will catch typos like 'Model.Tittle' — unlike ViewBag which is dynamic.
*@

@{
    ViewData["Title"] = "Books";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Books</h2>
    <a asp-action="Create" class="btn btn-primary">+ Add Book</a>
</div>

@* ---- SEARCH AND SORT CONTROLS ---- *@
<form method="get" class="row g-2 mb-3">
    @*
        TAG HELPER: <form method="get"> submits filters as query string parameters.
        The inputs' 'name' attributes become the query string keys:
        ?search=dune&sort=author
    *@
    <div class="col-md-5">
        <input type="text" name="search" class="form-control"
               placeholder="Search by title..." value="@ViewBag.CurrentSearch" />
    </div>
    <div class="col-md-4">
        @*
            asp-items: binds a SelectList to the <select> options.
            ViewBag.SortOptions is populated in BooksController.Index() from BookSorter.
            This is the STRATEGY PATTERN in action — the controller picked the strategies,
            the view just renders the options.
        *@
        <select name="sort" class="form-select" asp-items="@ViewBag.SortOptions">
            <option value="">— Sort by —</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-secondary w-100">Filter</button>
    </div>
    @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch as string) || ViewBag.CurrentSort != null)
    {
        <div class="col-md-1">
            <a asp-action="Index" class="btn btn-outline-danger w-100" title="Clear">✕</a>
        </div>
    }
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No books found. <a asp-action="Create">Add one!</a></div>
}
else
{
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Category</th>
                <th>Year</th>
                <th>Price</th>
                <th>Available</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @*
                @foreach in Razor: iterates the model and renders a <tr> for each book.
                All C# expressions (@book.Title, @book.Price) are HTML-ENCODED by default.
                This prevents XSS: if a title contains <script>alert(1)</script>,
                Razor renders it as &lt;script&gt; — it shows as text, not executable code.
                To render raw HTML (unsafe!), use @Html.Raw(book.Title).
            *@
            @foreach (var book in Model)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.AuthorName</td>
                    <td>@book.CategoryName</td>
                    <td>@book.PublishedYear</td>
                    <td>@book.Price.ToString("C")</td>
                    <td>
                        @if (book.IsAvailable)
                        {
                            <span class="badge bg-success">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No</span>
                        }
                    </td>
                    <td class="text-end">
                        @*
                            asp-route-id: adds the id to the route: /Books/Details/5
                            Without this, the link would just go to /Books/Details.
                        *@
                        <a asp-action="Details" asp-route-id="@book.Id"
                           class="btn btn-sm btn-outline-info">Details</a>
                        <a asp-action="Edit" asp-route-id="@book.Id"
                           class="btn btn-sm btn-outline-warning">Edit</a>
                        <form asp-action="Delete" asp-route-id="@book.Id"
                              method="post" style="display:inline"
                              onsubmit="return confirm('Delete @book.Title?')">
                            @*
                                Hidden input __RequestVerificationToken:
                                [ValidateAntiForgeryToken] on the controller requires this token.
                                asp-action on a <form> tag automatically injects it when
                                antiforgery is enabled. This prevents CSRF attacks where a
                                malicious site tricks the user's browser into POSTing to your app.
                            *@
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
