@model BookLibrary.ViewModels.BookFormViewModel

@{
    ViewData["Title"] = "Add Book";
}

<h2>Add a New Book</h2>

@*
    RAZOR TAG HELPERS — Form submission:

    <form asp-action="Create">: generates <form method="post" action="/Books/Create">
      AND injects the CSRF token hidden field automatically.

    <label asp-for="Title">: reads the [Display(Name="Book Title")] annotation
      and generates <label for="Title">Book Title</label>.

    <input asp-for="Title">: generates the correct input type, name, id, value,
      and data-val-* attributes for client-side validation.

    <span asp-validation-for="Title">: renders the validation error message
      for Title if ModelState has an error for it.
*@

<div class="row">
    <div class="col-md-7">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            @*
                asp-validation-summary="ModelOnly": shows model-level errors (not property-level).
                Property-level errors appear next to each field via asp-validation-for.
                "All" would show all errors here instead.
            *@

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="AuthorId" class="form-label"></label>
                @*
                    <select asp-for="AuthorId" asp-items="Model.Authors">:
                    - asp-for="AuthorId" binds the selected value to AuthorId
                    - asp-items="Model.Authors" populates the options from the SelectList
                    - On POST, the selected value is bound back to AuthorId via model binding
                *@
                <select asp-for="AuthorId" asp-items="Model.Authors" class="form-select">
                    <option value="">— Select an author —</option>
                </select>
                <span asp-validation-for="AuthorId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label"></label>
                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                    <option value="">— Select a category —</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="PublishedYear" class="form-label"></label>
                    <input asp-for="PublishedYear" class="form-control" type="number" />
                    <span asp-validation-for="PublishedYear" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="PageCount" class="form-label"></label>
                    <input asp-for="PageCount" class="form-control" type="number" />
                    <span asp-validation-for="PageCount" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="ISBN" class="form-label"></label>
                    <input asp-for="ISBN" class="form-control" />
                    <span asp-validation-for="ISBN" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsAvailable" class="form-check-input" />
                <label asp-for="IsAvailable" class="form-check-label"></label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Add Book</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
    <div class="col-md-5">
        <div class="card bg-light">
            <div class="card-body small">
                <h6>What's Happening Here?</h6>
                <ul>
                    <li><strong>GET /Books/Create</strong>: Controller populates dropdowns and returns the empty form.</li>
                    <li><strong>POST /Books/Create</strong>: Model binder maps form fields to <code>BookFormViewModel</code>.</li>
                    <li><code>ModelState.IsValid</code> runs all <code>[Required]</code>, <code>[Range]</code> etc. validators.</li>
                    <li>On success: POST → redirect → GET (PRG pattern prevents double-submit).</li>
                    <li><code>[ValidateAntiForgeryToken]</code> prevents CSRF attacks.</li>
                    <li><code>[Bind(...)]</code> on the controller prevents over-posting.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@*
    @section Scripts: injects validation scripts at the bottom of the page.
    Client-side validation runs in the browser using jQuery Validate —
    no round-trip to the server needed for basic field checks.
    Server-side validation (ModelState) still runs as a fallback.
*@
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
