<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Book Library</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @*
        TAG HELPERS — asp-append-version="true":
        Appends a content hash to the URL: site.css?v=abc123
        This "cache busting" forces browsers to reload the file when its content changes,
        bypassing their cached version. ASP.NET Core computes the hash at startup.
    *@
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                @*
                    TAG HELPER: asp-controller / asp-action / asp-route-id
                    Razor renders these as a correct href at runtime:
                      <a href="/Home/Index">Book Library</a>
                    The advantage: if you rename a controller or action, the URL updates
                    automatically — no manual URL strings to maintain throughout your views.
                *@
                <a class="navbar-brand text-white" asp-controller="Home" asp-action="Index">
                    📚 Book Library
                </a>
                <button class="navbar-toggler bg-light" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Books" asp-action="Index">Books</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Authors" asp-action="Index">Authors</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Categories" asp-action="Index">Categories</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Home" asp-action="DiDemo">DI Demo</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" href="/swagger" target="_blank">API (Swagger)</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        @* Global alert messages from TempData (set in controllers after redirects) *@
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <main role="main" class="pb-3">
            @*
                @RenderBody(): This is where the content of each view is inserted.
                Every view that uses this layout "fills in" this slot.
                Think of _Layout as a page template; individual views provide the content.
            *@
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-4">
        <div class="container py-2">
            &copy; @DateTime.Now.Year — Book Library Learning Project
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @*
        @RenderSection("Scripts", required: false):
        Views can define a "Scripts" section to inject page-specific JavaScript.
        'required: false' means views that don't define this section don't fail.
        Example in a view:
          @section Scripts {
              <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
          }
    *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
