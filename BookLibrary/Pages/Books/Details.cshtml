@page "{id:int}"
@model DetailsModel
@*
    @page "{id:int}": adds a required integer route segment to the page's URL.
    URL pattern: /Books/Details/{id}  e.g. /Books/Details/5
    The {id:int} constraint ensures only integers are matched — /Books/Details/abc returns 404.

    Without this directive the id would arrive as a query string: /Books/Details?id=5
    Both work, but route segments are cleaner and more conventional for detail/edit pages.
*@
@{
    ViewData["Title"] = Model.Book.Title;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@Model.Book.Title</h2>
    <div>
        <a asp-page="./Edit" asp-route-id="@Model.Book.Id" class="btn btn-warning">Edit</a>
        <a asp-page="./Index" class="btn btn-outline-secondary ms-1">Back</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-3">Author</dt>
    <dd class="col-sm-9">@Model.Book.AuthorName</dd>

    <dt class="col-sm-3">Category</dt>
    <dd class="col-sm-9">@Model.Book.CategoryName</dd>

    <dt class="col-sm-3">ISBN</dt>
    <dd class="col-sm-9">@(Model.Book.ISBN ?? "—")</dd>

    <dt class="col-sm-3">Published</dt>
    <dd class="col-sm-9">@Model.Book.PublishedYear</dd>

    <dt class="col-sm-3">Pages</dt>
    <dd class="col-sm-9">@Model.Book.PageCount</dd>

    <dt class="col-sm-3">Price</dt>
    <dd class="col-sm-9">@Model.Book.Price.ToString("C")</dd>

    <dt class="col-sm-3">Available</dt>
    <dd class="col-sm-9">
        @if (Model.Book.IsAvailable)
        {
            <span class="badge bg-success">Available</span>
        }
        else
        {
            <span class="badge bg-secondary">Unavailable</span>
        }
    </dd>
</dl>

@if (!string.IsNullOrEmpty(Model.Book.Description))
{
    <h5>Description</h5>
    <p>@Model.Book.Description</p>
}
